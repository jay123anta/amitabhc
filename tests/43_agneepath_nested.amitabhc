// TEST: AGNEEPATH nested try-catch
// EXPECT: Outer try
// EXPECT: Inner caught
// EXPECT: Outer continues
LIGHTS
CAMERA
    AGNEEPATH
        BOLO "Outer try"
        AGNEEPATH
            VIJAY x = 1 / 0
        MRITYU err
            BOLO "Inner caught"
        KHATAM
        BOLO "Outer continues"
    MRITYU err
        BOLO "Outer caught"
    KHATAM
ACTION
